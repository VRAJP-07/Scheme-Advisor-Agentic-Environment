# Scheme Advisor Environment Configuration

# Provider: groq, openai, huggingface, or grok
API_PROVIDER=groq

# Your API Key (required for LLM actions)
API_KEY=your_api_key_here

# Model name to use (Optional - if not specified, uses provider default)
# Groq defaults: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768
# OpenAI defaults: gpt-4o-mini, gpt-4o, gpt-4-turbo
# HuggingFace: meta-llama/Meta-Llama-3-8B-Instruct, etc.
# Grok defaults: grok-2-latest, grok-beta
# Leave empty to use provider default
MODEL_NAME=

# Environment Settings
ENV_BASE_URL=http://localhost:8000
